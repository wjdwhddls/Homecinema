# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# 워커 산출물 (자동 생성, 재현 가능)
outputs/*
# 예외: 씬 라벨 자동 산출물은 baseline 비교용으로 보관 (각 ~20~80KB)
!outputs/scene_labels/
outputs/scene_labels/*
!outputs/scene_labels/scene_labels_*_auto.json
!outputs/scene_labels/clip_probs_*.json

# 입력 데이터 (용량 큼, yt-dlp로 재다운 가능)
data/trailers/*.mp4
data/trailers/*.webm
data/trailers/*.wav
!data/trailers/.gitkeep

# 모델 자산 (용량 큼, 외부 다운로드)
model/autoEQ/assets/*.pth
model/autoEQ/assets/audioset_tagging_cnn/

# LIRIS-ACCEDE 원본 데이터 (9.6GB data + annotations + features, 외부 다운로드)
dataset/autoEQ/liris/

# 트랙 5: Bandit v2 외부 clone + 체크포인트 (446MB)
# git clone https://github.com/ZFTurbo/Music-Source-Separation-Training.git tools/mss-training
# checkpoint: zenodo.org/records/12701995/files/checkpoint-eng.ckpt
tools/mss-training/

# 실험 임시 산출물 (분리 stem wav, backup wav 등 — 재생성 가능)
tmp/

# 백엔드 jobs (사용자 업로드 데이터)
backend/data/jobs/*/
!backend/data/jobs/.gitkeep

# 백엔드 임시 파일
backend/tmp/uploads/*
!backend/tmp/uploads/.gitkeep

# 환경 파일
.env
.env.local

# IDE
.vscode/
.idea/
*.swp

# Claude Code 로컬 세션 상태
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# 한국어 경로 이슈로 임시 생성된 OneDrive 잔존물 (있으면)
*.tmp

# ============================================
# Phase G — Push 대비 정리 (feat/v3-6-bandit-v2)
# ============================================
# 노트: evaluation/webmushra/ 의 audio·results 는 evaluation/.gitignore 가
# whitelist 방식으로 이미 처리 (calibration 톤·코드만 추적). 중복 규칙 미작성.

# Node modules (mobile/web 의존성 — 추가될 경우 대비)
node_modules/

# 미디어 catch-all 안전망 — 코드 디렉토리 외 위치에 audio 가 새로 생길 경우
# (*.wav 와 *.mp4 는 calibration 톤·테스트 fixture 가능성 있어 전역 미적용)
*.opus
*.flac
*.aac
*.m4a

# ============================================
# master 추가 (jongin: train_cog + 수도라벨링)
# ============================================
/dataset

# 외부 repo clone (가중치 포함. git clone + gdown으로 재현 가능)
third_party/

# 학습/추론 산출물 (재현 가능, GitHub 100MB 파일 제한 회피)
runs/

# Precomputed frozen features (재현 가능: ccmovies_preprocess.py)
data/features/
