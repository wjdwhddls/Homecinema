HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_SIZE_MB=500
UPLOAD_TMP_DIR=./tmp/uploads
JOBS_DATA_DIR=./data/jobs
CORS_ORIGINS=http://localhost:8081,http://localhost:3000
ALLOWED_EXTENSIONS=mp4,mov,mkv,avi,webm
DEV_FAKE_PROCESSED=false

# xRIR 모델 경로 (실제 환경에 맞게 절대경로 지정)
XRIR_REPO_PATH=/path/to/xRIR_code-main
XRIR_CHECKPOINT_PATH=/path/to/checkpoints/xRIR_ConvNeXT/best.pth
